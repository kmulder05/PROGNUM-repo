   "source": [
    "import numpy as np\n",
    "from numpy.polynomial.polynomial import polyvander\n",
    "from matplotlib.pyplot import *\n",
    "\n",
    "x = [2.5]\n",
    "y = [7]\n",
    "vdm = polyvander(x,(len(x)-1))\n",
    "Y = np.linalg.solve(vdm, y)\n",
    "print(Y)"
   ]
  },
